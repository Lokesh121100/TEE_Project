# ============================================================
# IntelSoft AI Service Desk — .gitignore
# ============================================================

# --- Secrets (NEVER PUSH) ---
.env
**/.env
.env.*
!.env.example

# --- Dev-only scripts (contain hardcoded credentials) ---
src/utils/

# --- Python Virtual Environments ---
.venv/
venv/
env/
**/venv/

# --- Python Cache ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# --- Generated / Temporary Files ---
*.log
data/accuracy_report.json
data/aria_governance.db

# --- OS Files ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/

# --- Artifacts ---
.gemini/
.gradio/
mcp/servicenow/venv/
