# ============================================
# ARIA v2.0 - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env FILE - IT CONTAINS SECRETS
# ============================================

# -------- API SERVER --------
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development  # development | staging | production
API_DEBUG=True

# -------- OLLAMA / AI ENGINE --------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=30

# -------- SERVICENOW --------
SERVICENOW_URL=https://dev273008.service-now.com
SERVICENOW_USER=admin
SERVICENOW_PASSWORD=your_password_here
SERVICENOW_TABLE=x_1941577_tee_se_0_ai_incident_demo

# -------- DATABASE (For Production) --------
DB_TYPE=sqlite  # sqlite | postgresql | mysql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aria_production
DB_USER=aria_admin
DB_PASSWORD=secure_password_here

# -------- LOGGING --------
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/aria.log
LOG_FORMAT=json  # json | text

# -------- SECURITY --------
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# -------- PERFORMANCE --------
CACHE_ENABLED=True
CACHE_TTL=3600
MAX_WORKERS=4

# -------- MONITORING --------
SENTRY_DSN=  # Leave empty if not using Sentry
DATADOG_API_KEY=  # Leave empty if not using Datadog

# -------- FEATURES --------
ENABLE_AUTO_RESOLUTION=True
ENABLE_ESCALATION=True
ENABLE_AUDIT_LOGGING=True
